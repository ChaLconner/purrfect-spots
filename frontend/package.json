{
  "name": "purrfect-spots-frontend",
  "private": true,
  "version": "3.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "build:prod": "NODE_OPTIONS=--max-old-space-size=4096 vue-tsc && NODE_OPTIONS=--max-old-space-size=4096 vite build --mode production",
    "build:analyze": "vite build --mode production && npx source-map-explorer dist/assets/js/*.js",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test && npm run test:e2e",
    "lint": "eslint src --fix",
    "lint:check": "eslint src",
    "format": "prettier --write src/**/*.{ts,vue,css}",
    "deploy": "vercel --prod",
    "deploy:preview": "vercel",
    "generate-api": "npx openapi-typescript http://127.0.0.1:8000/openapi.json -o src/types/api.ts"
  },
  "dependencies": {
    "@googlemaps/js-api-loader": "^2.0.1",
    "@googlemaps/markerclusterer": "^2.6.2",
    "@sentry/vue": "^10.39.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tailwindcss/vite": "^4.2.0",
    "@types/dompurify": "^3.0.5",
    "apexcharts": "^5.10.4",
    "axios": "^1.8.2",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.6",
    "lodash": "^4.18.1",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.1.13",
    "vue": "^3.5.30",
    "vue-i18n": "^11.2.8",
    "vue-router": "^5.0.3",
    "vue-virtual-scroller": "^2.0.0-beta.8",
    "vue3-apexcharts": "^1.11.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.42.0",
    "@types/google.maps": "^3.58.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.5.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.2",
    "@vue/test-utils": "^2.4.0",
    "@vue/tsconfig": "^0.9.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^29.0.1",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.3.0",
    "sharp": "^0.34.5",
    "svgo": "^4.0.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.53.0",
    "vite": "^8.1.0",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-image-optimizer": "^2.0.3",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.2",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.5"
  }
}
