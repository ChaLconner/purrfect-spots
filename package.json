{
  "name": "purrfect-spots",
  "version": "1.0.0",
  "private": true,
  "description": "**Connect. Share. Discover.**\r The ultimate platform for cat lovers to find and share the perfect spots for their furry friends.",
  "main": "index.js",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "test": "npm test -w frontend",
    "prepare": "node -e \"if (!process.env.VERCEL) try { require('child_process').execSync('husky', {stdio: 'inherit'}) } catch (e) {}\"",
    "install:frontend": "npm install -w frontend",
    "build:frontend": "npm run build -w frontend",
    "build": "npm run build:frontend",
    "dev": "npm run dev -w frontend"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChaLconner/purrfect-spots.git"
  },
  "keywords": [],
  "author": "ChaLconner",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=24 <26"
  },
  "bugs": {
    "url": "https://github.com/ChaLconner/purrfect-spots/issues"
  },
  "homepage": "https://github.com/ChaLconner/purrfect-spots#readme",
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "vite": "8.0.8"
  },
  "lint-staged": {
    "backend/**/*.py": [
      "ruff check --fix",
      "ruff format"
    ],
    "frontend/src/**/*.{ts,vue}": [
      "bash -c 'cd frontend && npx eslint --fix'"
    ],
    "frontend/src/**/*.css": [
      "bash -c 'cd frontend && npx prettier --write'"
    ]
  },
  "overrides": {
    "vue": "3.5.32",
    "vite": "$vite",
    "js-beautify": {
      "editorconfig": "^3.0.1",
      "glob": {
        "minimatch": "10.2.4"
      }
    },
    "minimatch": ">=10.2.1",
    "serialize-javascript": "7.0.5",
    "openapi-typescript": {
      "typescript": ">=5.0.0"
    }
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-darwin-arm64": "4.2.1",
    "@tailwindcss/oxide-darwin-x64": "4.2.1",
    "@tailwindcss/oxide-linux-arm64-gnu": "4.2.1",
    "@tailwindcss/oxide-linux-x64-gnu": "4.2.1"
  }
}
