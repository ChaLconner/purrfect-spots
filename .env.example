# ================================
# ROOT ENV EXAMPLE - Purrfect Spots
# ================================

# --- Server ---
ENVIRONMENT=development
DEBUG=True
PORT=8000
FRONTEND_URL=http://localhost:5173

# --- Google APIs ---
GOOGLE_AI_API_KEY=your_google_ai_key_here
GOOGLE_MAPS_API_KEY=your_google_maps_key_here
GOOGLE_VISION_API_KEY=your_vision_key_here
GOOGLE_VISION_KEY_PATH=keys/google_vision.json

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here

# --- Frontend (Vite) ---
VITE_API_BASE_URL=http://localhost:8000
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-production-app.vercel.app
TRUSTED_PROXY_HOSTS=127.0.0.1,::1

# --- JWT ---
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
DATABASE_URL=postgresql://postgres.your-project-ref:your_database_password@aws-0-your-region.pooler.supabase.com:5432/postgres

# --- AWS ---
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_S3_BUCKET=your_bucket_name_here
AWS_REGION=ap-southeast-2

# --- Redis ---
REDIS_URL=your_redis_url_here

# --- EMAIL (Resend) ---
SMTP_SERVER=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=your_resend_password_here
SMTP_SENDER="Purrfect Spots <noreply@mail.purrfectspots.xyz>"

# --- Sentry ---
SENTRY_DSN=your_sentry_dsn_here
SENTRY_TRACES_SAMPLE_RATE=0.1
# Required for Sentry release tracking in CI/CD (GitHub Actions secrets)
# SENTRY_AUTH_TOKEN -> Sentry > Settings > Auth Tokens > Create (scope: project:releases)
# SENTRY_ORG       -> Your Sentry organization slug (e.g. "chalconner")
# SENTRY_PROJECT   -> Your Sentry project slug (e.g. "purrfect-spots")
SENTRY_AUTH_TOKEN=your_sentry_auth_token_here
SENTRY_ORG=your_sentry_org_slug
SENTRY_PROJECT=your_sentry_project_slug

# --- Stripe ---
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_webhook_secret_here
STRIPE_PRO_PRICE_ID=your_stripe_pro_price_id
STRIPE_PRO_ANNUAL_PRICE_ID=your_stripe_pro_annual_price_id

# --- Health / Ops ---
EXPOSE_DETAILED_HEALTH=false
